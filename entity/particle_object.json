{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "hp4_paint:particle_objects",
            "materials": {
                "default": "hp4_paint.outline_base"
            },
            "textures": {
                "hammer": "textures/hp/mp/particle_objects/hammer",
                "chisel": "textures/hp/mp/particle_objects/chisel",
                "brush": "textures/hp/mp/furnitures/painting_brush"
            },
            "geometry": {
                "hammer": "geometry.hp4_paint.hammer",
                "chisel": "geometry.hp4_paint.chisel",
                "brush": "geometry.hp4_paint.brush"
            },
            "render_controllers": [
                "controller.render.hp4_paint.particle_objects"
            ],
            "animations": {
                "hammer": "animation.hp4_paint.hammer.particle",
                "chisel": "animation.hp4_paint.chisel.particle",
                "brush": "animation.hp4_paint.brush.particle",
                "hammer_paroff": "animation.hp4_paint.hammer.particle_paroff",
                "chisel_paroff": "animation.hp4_paint.chisel.particle_paroff",
                "brush_paroff": "animation.hp4_paint.brush.particle_paroff"
            },
            "scripts": {
                "animate": [
                    {"hammer": "v.model == 0 && v.withpar"},
                    {"chisel": "v.model == 1 && v.withpar"},
                    {"brush": "v.model == 2 && v.withpar"},
                    {"hammer_paroff": "v.model == 0 && !v.withpar"},
                    {"chisel_paroff": "v.model == 1 && !v.withpar"},
                    {"brush_paroff": "v.model == 2 && !v.withpar"}
                ],
                "pre_animation": [
                    "v.model = q.property('hp4_paint:model');",
                    "v.withpar = q.property('hp4_paint:withpar');"
                ]
            },
            "particle_effects": {
                "hammer_hit": "test:dust_hammer_hit",
                "hammer_fx2": "test:h_fx2",
                "stone": "test:chiesel_fx1"
            }

        }
    }
}