                    "v.frame_16x16 = v.frame_size == 0;",
                    "v.frame_16x32 = v.frame_size == 1;",
                    "v.frame_32x16 = v.frame_size == 2;",
                    "v.frame_32x32 = v.frame_size == 3;",
                    "v.frame_32x64 = v.frame_size == 4;",
                    "v.frame_48x48 = v.frame_size == 5;",
                    "v.frame_48x64 = v.frame_size == 6;",
                    "v.frame_64x32 = false;",
                    "v.frame_64x48 = v.frame_size == 8;",
                    "v.frame_64x64 = v.frame_size == 9;",

                    
                    "v.amount_16x16 = 8;",
                    "v.amount_16x32 = 5;",
                    "v.amount_32x16 = 3;",
                    "v.amount_32x32 = 11;",
                    "v.amount_32x64 = 5;",
                    "v.amount_48x48 = 8;",
                    "v.amount_48x64 = 2;",
                    "v.amount_64x32 = 0;",
                    "v.amount_64x48 = 2;",
                    "v.amount_64x64 = 6;",

                    "v.colors = q.property('hp4_paint:paint_colors') + 1;",

                    "v.end_16x16 = v.amount_16x16;",
                    "v.end_16x32 = v.end_16x16 + v.amount_16x32;",
                    "v.end_32x16 = v.end_16x32 + v.amount_32x16;",
                    "v.end_32x32 = v.end_32x16 + v.amount_32x32;",
                    "v.end_32x64 = v.end_32x32 + v.amount_32x64;",
                    "v.end_48x48 = v.end_32x64 + v.amount_48x48;",
                    "v.end_48x64 = v.end_48x48 + v.amount_48x64;",
                    "v.end_64x32 = v.end_48x64 + v.amount_64x32;",
                    "v.end_64x48 = v.end_64x32 + v.amount_64x48;",
                    "v.end_64x64 = v.end_64x48 + v.amount_64x64;",

                    "v.frame_count = v.frame_16x16 ? v.amount_16x16 : v.frame_16x32 ? v.amount_16x32 : v.frame_32x16 ? v.amount_32x16 : v.frame_32x32 ? v.amount_32x32 : v.frame_32x64 ? v.amount_32x64 : v.frame_48x48 ? v.amount_48x48 : v.frame_48x64 ? v.amount_48x64 : v.frame_64x32 ? v.amount_64x32 : v.frame_64x48 ? v.amount_64x48 : v.frame_64x64 ? v.amount_64x64 : 0;"
                ],
