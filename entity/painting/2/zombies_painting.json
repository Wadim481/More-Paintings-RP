                        "huge_32": "q.property('hp4_paint:size') == 2 && q.property('hp4_paint:displayer')=='display_case_huge'"
                    },
                    {
                        "huge_64": "q.property('hp4_paint:size') == 4 && q.property('hp4_paint:displayer')=='display_case_huge'"
                    },
                    {
                        "tall_16": "q.property('hp4_paint:size') == 1 && q.property('hp4_paint:displayer')=='display_case_tall'"
                    },
                    {
                        "tall_32": "q.property('hp4_paint:size') == 2 && q.property('hp4_paint:displayer')=='display_case_tall'"
                    },
